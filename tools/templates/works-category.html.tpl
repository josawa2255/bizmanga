  <title>{{title_seo}}</title>
  <meta name="description" content="{{description}}">
  <meta name="keywords" content="{{keywords}}">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="{{url}}">
  <link rel="alternate" hreflang="ja" href="{{url}}">
  <link rel="alternate" hreflang="x-default" href="{{url}}">
  <!-- OG -->
  <meta property="og:title" content="{{title_seo}}">
  <meta property="og:description" content="{{description}}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{url}}">
  <meta property="og:site_name" content="ビズマンガ">
  <meta property="og:image" content="{{og_image}}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{kw_short}}制作事例｜ビズマンガ">
  <meta property="og:locale" content="ja_JP">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content="@Bizmanga_">
  <meta name="twitter:creator" content="@Bizmanga_">
  <meta name="twitter:title" content="{{title_seo}}">
  <meta name="twitter:description" content="{{description}}">
  <meta name="twitter:image" content="{{og_image}}">
  <meta name="twitter:image:alt" content="{{kw}}制作事例｜ビズマンガ">
  <link rel="icon" type="image/png" href="https://contentsx.jp/material/images/logo/bizmanga-icon.png">
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#e85500">
  <link rel="stylesheet" href="/css/bizmanga.css">
  <link rel="stylesheet" href="/css/bm-works-category.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
  <!-- JSON-LD: BreadcrumbList -->
  <script type="application/ld+json">
{{breadcrumb_jsonld}}
  </script>
  <!-- JSON-LD: CollectionPage + ItemList -->
  <script type="application/ld+json">
{{itemlist_jsonld}}
  </script>
  <!-- JSON-LD: FAQ -->
  <script type="application/ld+json">
{{faq_jsonld}}
  </script>
  <!-- JSON-LD: Organization -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://bizmanga.contentsx.jp/#organization",
    "name": "ビズマンガ",
    "alternateName": ["BizManga", "ビズ漫画"],
    "url": "https://bizmanga.contentsx.jp/",
    "logo": "https://contentsx.jp/material/images/logo/bizmanga-logo.webp",
    "sameAs": ["https://x.com/Bizmanga_", "https://contentsx.jp/"],
    "parentOrganization": {
      "@type": "Organization",
      "name": "Contents X 株式会社",
      "url": "https://contentsx.jp/"
    }
  }
  </script>
</head>
<body data-fuwa-auto>

  <!-- ===== ヘッダー ===== -->
  <header class="bm-header" id="header">
    <div class="bm-header-inner">
      <a href="/" class="bm-logo">
        <img src="https://contentsx.jp/material/images/logo/bizmanga-logo.webp" alt="BizManga" class="bm-logo-img" width="140" height="40">
      </a>
      <nav class="bm-nav" id="bmNav"></nav>
      <div class="bm-header-right">
        <a href="/contact" class="bm-nav-cta" data-ja="お問い合わせ" data-en="Contact">お問い合わせ</a>
        <a href="https://line.me/R/ti/p/@626kzaze?oat_content=url&ts=01071831" class="bm-nav-cta bm-nav-cta--line" target="_blank" rel="noopener" aria-label="LINEで相談">
          <svg class="bm-nav-cta-line-icon" viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 5.93 2 10.66c0 2.73 1.44 5.17 3.7 6.76-.13.47-.84 3.05-.87 3.26 0 0-.02.16.08.22s.21.02.21.02c.28-.04 3.24-2.12 3.75-2.48.96.14 1.95.22 2.96.22h.17c5.52 0 10-3.93 10-8.66S17.52 2 12 2z"/></svg>
          <span data-ja="LINEで相談" data-en="Chat on LINE">LINEで相談</span>
        </a>
        <button class="bm-hamburger" id="bmHamburger" aria-label="メニュー">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </header>

  <main class="bm-cat-page">
    <div class="bm-container">
      <!-- ===== パンくず ===== -->
      <nav class="bm-cat-breadcrumb" aria-label="breadcrumb">
        <a href="/">ホーム</a> <span aria-hidden="true">›</span>
        <a href="/works">制作事例</a> <span aria-hidden="true">›</span>
        <span aria-current="page">{{kw}}</span>
      </nav>

      <!-- ===== ヒーロー ===== -->
      <header class="bm-cat-hero">
        <p class="bm-cat-eyebrow">CASE STUDIES</p>
        <h1 class="bm-cat-title">「{{kw_short}}」の制作事例</h1>
        <p class="bm-cat-lead">{{intro_lead}}</p>
        <p class="bm-cat-count">該当事例 <strong>{{count}}件</strong></p>
      </header>

      <!-- ===== カテゴリナビ（横スクロール） ===== -->
      <nav class="bm-cat-nav" aria-label="カテゴリ">
{{cat_nav_html}}
      </nav>

      <!-- ===== 事例グリッド ===== -->
      <section class="bm-cat-grid-section" aria-labelledby="cat-cases-heading">
        <h2 id="cat-cases-heading" class="bm-cat-section-heading">{{kw_short}}の制作事例一覧</h2>
        <div class="bm-works-grid">
{{cards_html}}
        </div>
      </section>

      <!-- ===== 解説 ===== -->
      <section class="bm-cat-explain" aria-labelledby="cat-explain-heading">
        <h2 id="cat-explain-heading" class="bm-cat-section-heading">{{kw_short}}とは｜活用シーンと効果</h2>
        <p>{{usecase_text}}</p>
        <p>ビズマンガでは、課題ヒアリングからシナリオ設計・作画・納品まで一気通貫で対応。{{kw_short}}用途の制作実績を活かし、貴社の業界・ターゲット・媒体に合わせて最適なストーリーを設計します。</p>
        <p class="bm-cat-explain-cta">
          {{kw_short}}の料金・制作の流れ・FAQをまとめた専用ページもご覧いただけます。<br>
          <a class="bm-cat-explain-link" href="{{lp_path}}">{{lp_label}}の詳細を見る →</a>
        </p>
      </section>

      <!-- ===== FAQ ===== -->
      <section class="bm-cat-faq" aria-labelledby="cat-faq-heading">
        <h2 id="cat-faq-heading" class="bm-cat-section-heading">{{kw_short}}制作｜よくあるご質問</h2>
        <div class="bm-cat-faq-list">
{{faq_html}}
        </div>
      </section>

      <!-- ===== CTA ===== -->
      <section class="bm-cat-cta" aria-labelledby="cat-cta-heading">
        <h2 id="cat-cta-heading">{{kw_short}}の制作をご検討中の方へ</h2>
        <p>事例にあるような構成・演出を、貴社の課題に合わせてカスタマイズしてご提案します。お見積もり・サンプル送付は無料です。</p>
        <div class="bm-cat-cta-buttons">
          <a class="bm-cat-cta-btn bm-cat-cta-btn--primary" href="/contact">無料で相談する</a>
          <a class="bm-cat-cta-btn bm-cat-cta-btn--secondary" href="{{lp_path}}">{{lp_label}}の詳細</a>
          <a class="bm-cat-cta-btn bm-cat-cta-btn--line" href="https://line.me/R/ti/p/@626kzaze?oat_content=url&ts=01071831" target="_blank" rel="noopener">LINEで相談</a>
        </div>
      </section>
    </div>
  </main>

  <!-- ===== フッター ===== -->
  <footer class="bm-footer">
    <div class="bm-container">
      <div class="bm-footer-inner">
        <div class="bm-footer-brand">
          <img src="https://contentsx.jp/material/images/logo/bizmanga-logo.webp" alt="BizManga" class="bm-logo-img" width="140" height="40">
          <p class="bm-footer-company">Contents X 株式会社</p>
          <p class="bm-footer-address">東京都目黒区中目黒1-8-8 目黒F2ビル1F</p>
        </div>
        <div class="bm-footer-links">
          <a href="/">ホーム</a>
          <a href="/works">制作事例</a>
          <a href="/biz-library">ビズ書庫</a>
          <a href="/pricing">料金</a>
          <a href="/faq">FAQ</a>
          <a href="/contact">お問い合わせ</a>
          <a href="/privacy-policy">プライバシーポリシー</a>
        </div>
      </div>
      <div class="bm-footer-bottom">
        <p>© Contents X Co., Ltd. 2026 All rights reserved.</p>
        <a href="https://contentsx.jp/" class="bm-footer-parent">ContentsX Corporate Site →</a>
      </div>
    </div>
  </footer>

  <script src="/js/bm-sanitize.js" defer></script>
  <script src="/js/bm-i18n.js" defer></script>
  <script src="/js/bm-nav.js" defer></script>
  <script src="/js/bm-kinsoku.js" defer></script>
  <script src="/js/bm-tracking.js" defer></script>
  <script src="/js/bm-fuwa.js" defer></script>
</body>
</html>
